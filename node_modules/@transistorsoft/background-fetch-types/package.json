{
  "name": "@transistorsoft/background-fetch-types",
  "version": "1.0.0",
  "description": "TypeScript type definitions for the Transistor Software Background Fetch SDK",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json -w",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "background-fetch",
    "react-native",
    "cordova",
    "capacitor",
    "flutter"
  ],
  "license": "MIT",
  "author": "Transistor Software <info@transistorsoft.com>"
}
